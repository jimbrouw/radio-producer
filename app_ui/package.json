{
  "name": "radio-compliance-hifi",
  "version": "1.0.0",
  "description": "80s Hi-Fi Interface for Radio Compliance Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Antigravity",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.antigravity.radiocompliance",
    "mac": {
      "category": "public.app-category.music"
    },
    "extraResources": [
      {
        "from": "../src",
        "to": "src"
      },
      {
        "from": "../bin",
        "to": "bin"
      },
      {
        "from": "../.env",
        "to": "."
      }
    ]
  },
  "dependencies": {
    "python-shell": "^5.0.0"
  }
}